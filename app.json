{
  "expo": {
    "name": "exdox",
    "slug": "exdox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "exdox",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.receiptflow.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Use the camera to capture receipts and invoices.",
        "NSPhotoLibraryUsageDescription": "Use the photo library to import receipt and invoice images.",
        "NSPhotoLibraryAddUsageDescription": "Save captured receipt and invoice images to your photo library when enabled."
      }
    },
    "android": {
      "package": "com.receiptflow.mobile",
      "usesCleartextTraffic": true,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-document-picker",
      "expo-image-picker",
      "expo-secure-store"
    ],
    "extra": {
      "appDisplayName": "exdox",
      "expensesApiUrl": "https://hz2zkm6jkf.execute-api.eu-west-2.amazonaws.com/prod/api/v1/expenses/process"
    }
  }
}
